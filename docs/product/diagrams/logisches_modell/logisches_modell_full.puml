@startuml
title Logisches Datenmodell


' =========================
' Enums
' =========================

enum Kontostatus {
    verifizierung_ausstehend
    aktiv
    gesperrt
    geloescht
}

enum Benutzerrolle {
    admin
    manager
    mitglied
    ausleiher
}

enum Organisationstyp {
    schule
    hochschule
    unternehmen
    verein
    bibliothek
    sonstige
}

enum Tokentyp {
    email_verifizierung
    passwort_zuruecksetzen
}

enum Verifizierungsstatus {
    ausstehend
    genehmigt
    abgelehnt
}

enum Benachrichtigungstyp {
    anfrage_eingereicht
    anfrage_genehmigt
    anfrage_abgelehnt
    klaerung_erforderlich
    ausleihe_uebergabe_erinnerung
    ausleihe_bald_faellig
    ausleihe_ueberfaellig
    ausleihe_zurueckgegeben
    verlaengerung_genehmigt
    verlaengerung_abgelehnt
    reservierung_laeuft_ab
    allgemein
}

enum Benachrichtigungskanal {
    email
    in_app
    sms
    push
}

enum Benachrichtigungsstatus {
    ausstehend
    gesendet
    fehlgeschlagen
    gelesen
}

enum Ausleihanfragestatus {
    entwurf
    eingereicht
    klaerung_erforderlich
    genehmigt
    abgelehnt
    zurueckgezogen
    abgelaufen
}

enum Ausleihstatus {
    aktiv
    zurueckgegeben
    storniert
}

enum Faelligkeitsstatus {
    fristgerecht
    bald_faellig
    ueberfaellig
}

enum Verlaengerungsstatus {
    ausstehend
    genehmigt
    abgelehnt
    storniert
}

enum Verfuegbarkeitsstatus {
    verfuegbar
    reserviert
    ausgeliehen
    nicht_verfuegbar
    in_reparatur
    verloren
}

enum Zustandsstatus {
    gut
    beschaedigt
    defekt
    verloren
}

enum Reservierungsstatus {
    aktiv
    erfuellt
    storniert
    abgelaufen
}

enum Protokolltyp {
    uebergabe
    rueckgabe
}

' =========================
' Benutzer und Organisation
' =========================

entity "BENUTZER" as BENUTZER {
    vollstaendiger_name : string
    email : string
    passwort_hash : string
    telefonnummer : string
    rolle : Benutzerrolle
    kontostatus : Kontostatus
    email_verifiziert_am : datetime
    datenschutzerklaerung_akzeptiert_am : datetime
    erstellt_am : datetime
    aktualisiert_am : datetime
    letzte_anmeldung_am : datetime
}

entity "ORGANISATION" as ORGANISATION {
    name : string
    organisationstyp : Organisationstyp
    erstellt_am : datetime
}

entity "BENUTZER_VERIFIZIERUNG" as BENUTZER_VERIFIZIERUNG {
    methode : string
    status : Verifizierungsstatus
    gueltig_bis : datetime
    verifiziert_am : datetime
    erstellt_am : datetime
}

entity "AUTH_TOKEN" as AUTH_TOKEN {
    token_typ : Tokentyp
    token_hash : string
    gueltig_bis : datetime
    verwendet_am : datetime
    erstellt_am : datetime
}

entity "BENACHRICHTIGUNG" as BENACHRICHTIGUNG {
    benachrichtigungstyp : Benachrichtigungstyp
    kanal : Benachrichtigungskanal
    bezugsobjekt_typ : string
    bezugsobjekt_referenz : string
    nachricht : string
    status : Benachrichtigungsstatus
    erstellt_am : datetime
    gesendet_am : datetime
    gelesen_am : datetime
}

' =========================
' Inventar
' =========================

entity "KATEGORIE" as KATEGORIE {
    name : string
    beschreibung : string
}

entity "STANDORT" as STANDORT {
    name : string
    beschreibung : string
}

entity "GEGENSTAND" as GEGENSTAND {
    name : string
    beschreibung : string
    verwendungszweck_erforderlich : boolean
    minimale_ausleihtage : int
    maximale_ausleihtage : int
    geplante_anzahl : int
    ist_geloescht : boolean
    erstellt_am : datetime
    aktualisiert_am : datetime
}

entity "GEGENSTAND_BILD" as GEGENSTAND_BILD {
    bild_url : string
    beschriftung : string
    anzeigereihenfolge : int
    ist_hauptbild : boolean
    hochgeladen_am : datetime
}

entity "GEGENSTAND_EINHEIT" as GEGENSTAND_EINHEIT {
    inventarnummer : string
    zustandsstatus : Zustandsstatus
    verfuegbarkeitsstatus : Verfuegbarkeitsstatus
    status_aktualisiert_am : datetime
    erstellt_am : datetime
}

entity "GEGENSTAND_STATUS_HISTORIE" as GEGENSTAND_STATUS_HISTORIE {
    alter_status : string
    neuer_status : string
    grund : string
    geaendert_am : datetime
}

' =========================
' Ausleihanfrage
' =========================

entity "AUSLEIHANFRAGE" as AUSLEIHANFRAGE {
    gewuenschtes_startdatum : date
    gewuenschtes_rueckgabedatum : date
    verwendungszweck : string
    status : Ausleihanfragestatus
    ablehnungsgrund : string
    eingereicht_am : datetime
    geprueft_am : datetime
    erstellt_am : datetime
    aktualisiert_am : datetime
}

entity "AUSLEIHANFRAGE_POSITION" as AUSLEIHANFRAGE_POSITION {
    angefragte_menge : int
    verfuegbarkeit_geprueft_am : datetime
    verfuegbarkeitsergebnis : string
}

entity "AUSLEIHANFRAGE_STATUS_HISTORIE" as AUSLEIHANFRAGE_STATUS_HISTORIE {
    alter_status : string
    neuer_status : string
    kommentar : string
    geaendert_am : datetime
}

entity "AUSLEIHANFRAGE_NACHRICHT" as AUSLEIHANFRAGE_NACHRICHT {
    inhalt : string
    ist_interne_notiz : boolean
    erstellt_am : datetime
}

' =========================
' Reservierung
' =========================

entity "RESERVIERUNG" as RESERVIERUNG {
    reservierungs_startdatum : date
    reservierungs_enddatum : date
    status : Reservierungsstatus
    notiz : string
    erstellt_am : datetime
    aktualisiert_am : datetime
}

' =========================
' Ausleihe
' =========================

entity "AUSLEIHE" as AUSLEIHE {
    ausleihdatum : date
    uebergeben_am : datetime
    faelligkeitsdatum : date
    rueckgabe_angefragt_am : datetime
    tatsaechliches_rueckgabedatum : date
    status : Ausleihstatus
    / faelligkeitsstatus : Faelligkeitsstatus
    erstellt_am : datetime
    aktualisiert_am : datetime
}

entity "AUSLEIHE_POSITION" as AUSLEIHE_POSITION {
}

entity "AUSLEIHE_VERLAENGERUNG" as AUSLEIHE_VERLAENGERUNG {
    altes_faelligkeitsdatum : date
    neues_faelligkeitsdatum : date
    status : Verlaengerungsstatus
    grund : string
    erstellt_am : datetime
}

' =========================
' Bedingungen und Bestätigung
' =========================

entity "NUTZUNGSBEDINGUNGEN" as NUTZUNGSBEDINGUNGEN {
    version : string
    text : string
    gueltig_ab : datetime
    gueltig_bis : datetime
    erstellt_am : datetime
}

entity "BEDINGUNGS_ANNAHME" as BEDINGUNGS_ANNAHME {
    akzeptiert_am : datetime
}

entity "BUCHUNGSBESTAETIGUNG" as BUCHUNGSBESTAETIGUNG {
    dokument_url : string
    generiert_am : datetime
    an_ausleiher_gesendet_am : datetime
    an_verleiher_gesendet_am : datetime
}

' =========================
' Zustandsprotokoll
' =========================

entity "ZUSTANDSPROTOKOLL" as ZUSTANDSPROTOKOLL {
    protokolltyp : Protokolltyp
    allgemeine_notiz : string
    erstellt_am : datetime
}

entity "ZUSTANDSPROTOKOLL_POSITION" as ZUSTANDSPROTOKOLL_POSITION {
    zustandsstatus : Zustandsstatus
    schadensbeschreibung : string
    foto_url : string
}

' =========================
' Notizen
' =========================

note right of AUSLEIHANFRAGE_POSITION
angefragte_menge muss groesser als 0 sein.

verfuegbarkeit_geprueft_am speichert, wann das System
geprueft hat, ob der angefragte Gegenstand
fuer den ausgewaehlten Zeitraum verfuegbar war.

verfuegbarkeitsergebnis speichert das Ergebnis dieser Pruefung,
zum Beispiel: verfuegbar, teilweise_verfuegbar
oder nicht_verfuegbar.
end note

note right of RESERVIERUNG
Eine Reservierung blockiert eine konkrete Gegenstandseinheit
fuer einen bestimmten Benutzer und Zeitraum.

Normalerweise wird eine Reservierung erstellt, nachdem
eine Ausleihanfrage genehmigt wurde und bevor
der Gegenstand uebergeben wird.
end note

' =========================
' Beziehungen
' =========================

ORGANISATION "1" -- "0..*" BENUTZER : hat_benutzer

BENUTZER "1" -- "0..*" BENUTZER_VERIFIZIERUNG : ist_betroffen
BENUTZER "0..1" -- "0..*" BENUTZER_VERIFIZIERUNG : fuehrt_durch

BENUTZER "1" -- "0..*" AUTH_TOKEN : erhaelt
BENUTZER_VERIFIZIERUNG "0..1" -- "0..1" AUTH_TOKEN : nutzt_token
BENUTZER "1" -- "0..*" BENACHRICHTIGUNG : erhaelt
BENUTZER "0..1" -- "0..*" BENACHRICHTIGUNG : gesendet_von

ORGANISATION "1" o-- "0..*" KATEGORIE : verwaltet
ORGANISATION "1" o-- "0..*" STANDORT : verwaltet

KATEGORIE "1" -- "0..*" GEGENSTAND : kategorisiert
STANDORT "0..1" -- "0..*" GEGENSTAND : standard_standort

ORGANISATION "1" -- "0..*" GEGENSTAND : besitzt

GEGENSTAND "1" *-- "0..*" GEGENSTAND_BILD : hat_bilder
BENUTZER "0..1" -- "0..*" GEGENSTAND_BILD : hochgeladen_von

GEGENSTAND "1" *-- "1..*" GEGENSTAND_EINHEIT : besteht_aus
STANDORT "1" -- "0..*" GEGENSTAND_EINHEIT : lagert

GEGENSTAND_EINHEIT "1" -- "0..*" GEGENSTAND_STATUS_HISTORIE : hat_statusaenderungen
BENUTZER "1" -- "0..*" GEGENSTAND_STATUS_HISTORIE : aendert_status

BENUTZER "1" -- "0..*" AUSLEIHANFRAGE : erstellt
ORGANISATION "1" -- "0..*" AUSLEIHANFRAGE : erhaelt
BENUTZER "0..1" -- "0..*" AUSLEIHANFRAGE : prueft

AUSLEIHANFRAGE "1" *-- "1..*" AUSLEIHANFRAGE_POSITION : enthaelt
GEGENSTAND "1" -- "0..*" AUSLEIHANFRAGE_POSITION : angefragter_gegenstand

AUSLEIHANFRAGE "1" -- "0..*" AUSLEIHANFRAGE_STATUS_HISTORIE : hat_historie
BENUTZER "1" -- "0..*" AUSLEIHANFRAGE_STATUS_HISTORIE : aendert_status

AUSLEIHANFRAGE "1" *-- "0..*" AUSLEIHANFRAGE_NACHRICHT : hat_nachrichten
BENUTZER "1" -- "0..*" AUSLEIHANFRAGE_NACHRICHT : verfasst_von

AUSLEIHANFRAGE "0..1" -- "0..*" RESERVIERUNG : fuehrt_zu
AUSLEIHANFRAGE_POSITION "1" -- "0..*" RESERVIERUNG : erzeugt_reservierungen
GEGENSTAND_EINHEIT "1" -- "0..*" RESERVIERUNG : reserviert
BENUTZER "1" -- "0..*" RESERVIERUNG : reserviert_fuer

AUSLEIHANFRAGE "0..1" -- "0..1" AUSLEIHE : wird_zu

BENUTZER "1" -- "0..*" AUSLEIHE : entleiht
BENUTZER "0..1" -- "0..*" AUSLEIHE : verleiht
ORGANISATION "1" -- "0..*" AUSLEIHE : verleihende_organisation

AUSLEIHE "1" *-- "1..*" AUSLEIHE_POSITION : enthaelt
RESERVIERUNG "0..1" -- "0..1" AUSLEIHE_POSITION : wird_ausgeliehen_als
GEGENSTAND_EINHEIT "1" -- "0..*" AUSLEIHE_POSITION : ausgeliehene_einheit

AUSLEIHE "1" o-- "0..*" AUSLEIHE_VERLAENGERUNG : hat_verlaengerungen
BENUTZER "1" -- "0..*" AUSLEIHE_VERLAENGERUNG : beantragt
BENUTZER "0..1" -- "0..*" AUSLEIHE_VERLAENGERUNG : genehmigt

NUTZUNGSBEDINGUNGEN "1" -- "0..*" BEDINGUNGS_ANNAHME : wird_akzeptiert_in
BENUTZER "1" -- "0..*" BEDINGUNGS_ANNAHME : akzeptiert
AUSLEIHANFRAGE "0..*" -- "1" BEDINGUNGS_ANNAHME : basiert_auf_annahme
AUSLEIHE "0..*" -- "1" BEDINGUNGS_ANNAHME : basiert_auf_annahme

AUSLEIHANFRAGE "1" -- "0..1" BUCHUNGSBESTAETIGUNG : generiert
AUSLEIHE "0..1" -- "0..1" BUCHUNGSBESTAETIGUNG : bestaetigt

AUSLEIHE "1" *-- "0..*" ZUSTANDSPROTOKOLL : hat_protokolle
BENUTZER "1" -- "0..*" ZUSTANDSPROTOKOLL : erstellt_von
BENUTZER "0..1" -- "0..*" ZUSTANDSPROTOKOLL : uebergeben_von
BENUTZER "0..1" -- "0..*" ZUSTANDSPROTOKOLL : angenommen_von

ZUSTANDSPROTOKOLL "1" *-- "1..*" ZUSTANDSPROTOKOLL_POSITION : enthaelt
GEGENSTAND_EINHEIT "1" -- "0..*" ZUSTANDSPROTOKOLL_POSITION : dokumentierte_einheit

' =========================
' Abhängigkeiten zu Aufzählungen
' =========================

BENUTZER ..> Kontostatus : verwendet
BENUTZER ..> Benutzerrolle : verwendet
ORGANISATION ..> Organisationstyp : verwendet

BENUTZER_VERIFIZIERUNG ..> Verifizierungsstatus : verwendet
AUTH_TOKEN ..> Tokentyp : verwendet

BENACHRICHTIGUNG ..> Benachrichtigungstyp : verwendet
BENACHRICHTIGUNG ..> Benachrichtigungskanal : verwendet
BENACHRICHTIGUNG ..> Benachrichtigungsstatus : verwendet

AUSLEIHANFRAGE ..> Ausleihanfragestatus : verwendet

AUSLEIHE ..> Ausleihstatus : verwendet
AUSLEIHE ..> Faelligkeitsstatus : verwendet

AUSLEIHE_VERLAENGERUNG ..> Verlaengerungsstatus : verwendet

GEGENSTAND_EINHEIT ..> Verfuegbarkeitsstatus : verwendet
GEGENSTAND_EINHEIT ..> Zustandsstatus : verwendet

RESERVIERUNG ..> Reservierungsstatus : verwendet

ZUSTANDSPROTOKOLL ..> Protokolltyp : verwendet
ZUSTANDSPROTOKOLL_POSITION ..> Zustandsstatus : verwendet

@enduml